rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regras para hospedagens
    match /hospedagens/{docId} {
      // Permitir leitura para usuários autenticados
      allow read: if request.auth != null;
      
      // Permitir atualização se o usuário estiver logado E (o documento original não tiver userId OU for o dono)
      allow update: if request.auth != null && (
        !('userId' in resource.data) || resource.data.userId == request.auth.uid
      );
      
      // Permitir exclusão apenas se for o dono do documento
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
      
      // Permitir criação apenas se o userId no documento criado for o do usuário logado
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // Regras para clientes
    match /clientes/{docId} {
      allow read: if request.auth != null;
      
      allow update: if request.auth != null && (
        !('userId' in resource.data) || resource.data.userId == request.auth.uid
      );
      
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
      
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // Regras para dados do usuário
    match /usuarios/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Regras para configurações do usuário
    match /configuracoes/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
